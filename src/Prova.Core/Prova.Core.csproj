<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible>true</IsAotCompatible>
    <RootNamespace>Prova</RootNamespace>
    <OutputType>Library</OutputType>
    <IsTestProject>false</IsTestProject>
    <EnableMicrosoftTestingPlatform>false</EnableMicrosoftTestingPlatform>
    <IsPackable>true</IsPackable>
    <Version>0.5.0</Version>

    <PackageId>Prova</PackageId>
    <Description>High-performance, AOT-safe testing framework for .NET.</Description>
    <Authors>Digvijay</Authors>
    <Company>Prova</Company>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Digvijay/Prova</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Digvijay/Prova.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>test testing aot mtp xunit playwright testcontainers</PackageTags>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\icon.png" Pack="true" PackagePath="\" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" Version="18.3.2" />
    <PackageReference Include="Microsoft.Testing.Platform" Version="2.0.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport.Abstractions" Version="2.0.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" Version="2.0.2" />
    <PackageReference Include="Microsoft.Testing.Platform.MSBuild" Version="2.0.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.CrashDump" Version="2.0.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.HangDump" Version="2.0.2" />
    
    <!-- Analyzer Reference for IDE/Build -->
    <ProjectReference Include="..\Prova.Generators\Prova.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\Prova.Analyzers\Prova.Analyzers.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />

    <!-- Explicitly Pack the Generator/Analyzer DLLs -->
    <None Include="..\Prova.Generators\bin\$(Configuration)\netstandard2.0\Prova.Generators.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="..\Prova.Analyzers\bin\$(Configuration)\netstandard2.0\Prova.Analyzers.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />

    <!-- Pack Build Props -->
    <None Include="build\Prova.props" Pack="true" PackagePath="build" />
  </ItemGroup>

</Project>
